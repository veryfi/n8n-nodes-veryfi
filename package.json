{
  "name": "n8n-nodes-veryfi",
  "version": "0.1.0",
  "description": "n8n community node for Veryfi document AI: extract structured data from invoices, receipts, checks, bank statements, W-9/W-2, IDs, and any document via blueprints.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "veryfi",
    "ocr",
    "document-ai",
    "document-extraction",
    "invoice",
    "receipt",
    "check",
    "w9",
    "w2",
    "bank-statement",
    "driver-license",
    "passport",
    "idp"
  ],
  "license": "MIT",
  "homepage": "https://github.com/veryfi/n8n-nodes-veryfi",
  "author": {
    "name": "Veryfi",
    "email": "support@veryfi.com",
    "url": "https://www.veryfi.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veryfi/n8n-nodes-veryfi.git"
  },
  "bugs": {
    "url": "https://github.com/veryfi/n8n-nodes-veryfi/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "test": "jest",
    "prepublishOnly": "pnpm test && n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/VeryfiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Veryfi/Veryfi.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@n8n/eslint-plugin-community-nodes": "^0.13.0",
    "@n8n/node-cli": "^0.28.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "eslint": "9.29.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
