{
	"name": "n8n-nodes-veryfi",
	"version": "0.1.0",
	"description": "n8n community node for Veryfi document AI: extract structured data from invoices, receipts, checks, bank statements, W-9/W-2, IDs, and any document via blueprints.",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"veryfi",
		"ocr",
		"document-ai",
		"document-extraction",
		"invoice",
		"receipt",
		"check",
		"w9",
		"w2",
		"bank-statement",
		"driver-license",
		"passport",
		"idp"
	],
	"license": "MIT",
	"homepage": "https://github.com/veryfi/n8n-nodes-veryfi",
	"author": {
		"name": "Veryfi",
		"email": "support@veryfi.com",
		"url": "https://www.veryfi.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/veryfi/n8n-nodes-veryfi.git"
	},
	"bugs": {
		"url": "https://github.com/veryfi/n8n-nodes-veryfi/issues"
	},
	"engines": {
		"node": ">=20.15"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json && gulp build:icons",
		"dev": "tsc -p tsconfig.build.json --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "pnpm build && pnpm lint && pnpm test",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/VeryfiApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Veryfi/Veryfi.node.js"
		]
	},
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/node": "^20.14.10",
		"@typescript-eslint/parser": "^7.15.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"gulp": "^5.0.0",
		"jest": "^29.7.0",
		"jest-mock-extended": "^3.0.7",
		"jsonc-eslint-parser": "^3.1.0",
		"n8n-workflow": "*",
		"prettier": "^3.3.3",
		"ts-jest": "^29.2.3",
		"typescript": "^5.5.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
